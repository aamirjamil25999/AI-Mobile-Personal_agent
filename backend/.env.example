NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_phone_agent
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
GOOGLE_CLIENT_IDS=
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
REFRESH_COOKIE_NAME=my_phone_agent_refresh
REFRESH_COOKIE_MAX_AGE_MS=2592000000
COOKIE_DOMAIN=
EXPOSE_DEV_OTP=true
PASSWORD_RESET_EXPIRY_MS=1800000
OTP_PROVIDER=DEV_LOG
OTP_DEFAULT_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
